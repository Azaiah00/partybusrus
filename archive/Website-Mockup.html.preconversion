/* MOCKUP FLOATING BUTTON */

/* MOCKUP FLOATING BUTTON */
.mockup-flag{position:fixed;bottom:22px;left:22px;background:var(--wine);color:#fff;padding:9px 16px;font-size:11px;letter-spacing:.12em;text-transform:uppercase;font-weight:700;border-radius:999px;z-index:300;box-shadow:0 10px 24px -8px rgba(0,0,0,.6)}

/* DROPDOWN NAV — bridged so it doesn't disappear when cursor moves down */
.dd{position:relative}
.dd-trigger{cursor:pointer;display:inline-flex;align-items:center;gap:5px;padding:8px 0;position:relative}
.dd-trigger .caret{font-size:9px;color:var(--gold);transition:transform .25s var(--ease)}
.dd:hover .caret{transform:rotate(180deg)}
.dd-menu{position:absolute;top:calc(100% + 14px);left:-14px;min-width:280px;background:#000;border:1px solid var(--line2);padding:10px 0;opacity:0;pointer-events:none;transform:translateY(-6px);transition:opacity .2s var(--ease),transform .2s var(--ease);z-index:101;box-shadow:0 20px 40px -10px rgba(0,0,0,.8)}
/* invisible hover bridge — covers the 14px gap so cursor doesn't lose hover state */
.dd-menu:before{content:"";position:absolute;bottom:100%;left:-6px;right:-6px;height:22px}
.dd:hover .dd-menu,.dd-menu:hover,.dd:focus-within .dd-menu{opacity:1;pointer-events:auto;transform:none}
.dd-menu a{display:block;padding:11px 20px;font-size:13px;color:#d8d8cc;text-transform:none;letter-spacing:.02em;font-weight:500;border:none;white-space:nowrap}
.dd-menu a:hover{background:rgba(212,175,55,.1);color:var(--gold2);text-decoration:none}
.dd-menu a:after{display:none}
.dd-menu a b{color:var(--gold2)}

/* BLOG */
.blog-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(320px,1fr));gap:28px}
.blog-card{background:var(--surf);border:1px solid var(--line);cursor:pointer;transition:all .35s var(--ease);overflow:hidden}
.blog-card:hover{transform:translateY(-4px);border-color:var(--gold2)}
.blog-card .img{aspect-ratio:16/10;background-size:cover;background-position:center;background-color:#1a1a22}
.blog-card .body{padding:24px 28px 26px}
.blog-card .cat{font-size:10px;letter-spacing:.2em;text-transform:uppercase;color:var(--gold);font-weight:600;margin-bottom:10px;display:block}
.blog-card h4{font-family:"Cormorant Garamond",serif;font-size:23px;font-weight:500;color:#fff;line-height:1.2;margin-bottom:10px}
.blog-card p{color:var(--mute);font-size:14px;margin-bottom:14px;line-height:1.55}
.blog-card .meta{display:flex;gap:14px;font-size:11.5px;color:var(--dim);letter-spacing:.06em}
.featured-post{display:grid;grid-template-columns:1.2fr 1fr;background:var(--surf);border:1px solid var(--gold);margin-bottom:60px;overflow:hidden}
@media(max-width:880px){.featured-post{grid-template-columns:1fr}}
.featured-post .img{min-height:340px;background-size:cover;background-position:center;background-color:#1a1a22}
.featured-post .body{padding:50px 48px}
.featured-post .cat{font-size:10px;letter-spacing:.2em;text-transform:uppercase;color:var(--gold);font-weight:600;margin-bottom:14px;display:block}
.featured-post h3{font-family:"Cormorant Garamond",serif;font-size:38px;font-weight:500;color:#fff;line-height:1.1;margin-bottom:18px}
.featured-post p{color:#bdbdb5;font-size:16px;line-height:1.6;margin-bottom:22px}

/* ARTICLE BODY */
.article{max-width:760px;margin:0 auto}
.article-meta{display:flex;gap:18px;padding-bottom:24px;margin-bottom:36px;border-bottom:1px solid var(--line);color:var(--mute);font-size:12.5px;letter-spacing:.06em}
.article-meta b{color:var(--gold2);text-transform:uppercase;font-weight:600}
.article p{color:#d6d6cc;font-size:17px;line-height:1.85;margin-bottom:22px}
.article h2{font-family:"Cormorant Garamond",serif;font-size:36px;color:#fff;margin:50px 0 18px;font-weight:500;line-height:1.15}
.article h3{font-family:"Cormorant Garamond",serif;font-size:26px;color:var(--gold2);margin:32px 0 12px;font-weight:500}
.article ul,.article ol{margin:18px 0;padding-left:24px;color:#d6d6cc;font-size:17px;line-height:1.85}
.article ul li,.article ol li{margin-bottom:10px}
.article blockquote{border-left:3px solid var(--gold);padding:8px 26px;margin:30px 0;font-family:"Cormorant Garamond",serif;font-style:italic;font-size:22px;color:#e8e8dc;line-height:1.5}
.article .price-callout{background:var(--bg2);border:1px solid var(--gold);padding:30px;margin:30px 0}
.article .price-callout b{display:block;font-family:"Cormorant Garamond",serif;font-size:26px;color:var(--gold2);margin-bottom:10px;font-weight:500}

/* GALLERY */
.gallery-grid{columns:3;column-gap:14px}
@media(max-width:880px){.gallery-grid{columns:2}}
@media(max-width:560px){.gallery-grid{columns:1}}
.gallery-grid .gi{margin-bottom:14px;display:block;background-size:cover;background-position:center;background-color:#1a1a22;border:1px solid var(--line);position:relative;overflow:hidden;cursor:pointer;transition:transform .35s var(--ease)}
.gallery-grid .gi:hover{transform:scale(1.01)}
.gallery-grid .gi:nth-child(3n+1){aspect-ratio:4/5}
.gallery-grid .gi:nth-child(3n+2){aspect-ratio:1}
.gallery-grid .gi:nth-child(3n+3){aspect-ratio:3/4}
.gallery-grid .gi .lbl{position:absolute;bottom:0;left:0;right:0;padding:14px 18px;background:linear-gradient(0deg,rgba(0,0,0,.9),transparent);color:#fff;font-family:"Cormorant Garamond",serif;font-size:18px;font-weight:500}
.gallery-filter{display:flex;gap:8px;flex-wrap:wrap;margin-bottom:40px;justify-content:center}
.gallery-filter button{background:transparent;border:1px solid var(--line2);color:#d8d8cc;padding:9px 18px;font-size:11px;letter-spacing:.14em;text-transform:uppercase;font-weight:600;font-family:inherit;cursor:pointer;transition:all .2s var(--ease)}
.gallery-filter button.active,.gallery-filter button:hover{background:var(--gold);color:#1a0e00;border-color:var(--gold)}

/* TEAM CARDS */
.team-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:24px;margin:30px 0}
.team-card{text-align:center}
.team-card .photo{width:100%;aspect-ratio:1;background:linear-gradient(135deg,#1a1a22,#22222d);border:1px solid var(--line2);display:flex;align-items:center;justify-content:center;font-family:"Cormorant Garamond",serif;font-style:italic;font-size:80px;color:var(--gold);font-weight:300;margin-bottom:18px}
.team-card h4{font-family:"Cormorant Garamond",serif;font-size:22px;color:#fff;font-weight:500;margin-bottom:4px}
.team-card .role{font-size:11px;letter-spacing:.18em;text-transform:uppercase;color:var(--gold2);font-weight:600;margin-bottom:8px}
.team-card p{font-size:13.5px;color:var(--mute);line-height:1.55}

/* STATS BAR */
.stats-bar{display:grid;grid-template-columns:repeat(4,1fr);gap:0;border:1px solid var(--line2)}
@media(max-width:680px){.stats-bar{grid-template-columns:repeat(2,1fr)}}
.stat-item{padding:36px 24px;text-align:center;border-right:1px solid var(--line)}
.stat-item:last-child{border-right:none}
.stat-item .n{font-family:"Cormorant Garamond",serif;font-size:54px;color:var(--gold2);font-weight:500;line-height:1;margin-bottom:8px}
.stat-item .l{font-size:11px;letter-spacing:.18em;text-transform:uppercase;color:var(--mute);font-weight:600}

/* CREDENTIAL ROWS */
.cred-row{display:grid;grid-template-columns:120px 1fr;gap:30px;padding:30px 0;border-bottom:1px solid var(--line);align-items:start}
@media(max-width:680px){.cred-row{grid-template-columns:1fr;gap:10px}}
.cred-row .seal{font-family:"Cormorant Garamond",serif;font-size:18px;color:var(--gold);border:1px solid var(--gold);padding:14px 16px;text-align:center;line-height:1.2;font-weight:500;letter-spacing:.04em}
.cred-row h4{font-family:"Cormorant Garamond",serif;font-size:24px;color:#fff;margin-bottom:8px;font-weight:500}
.cred-row p{color:var(--mute);font-size:14.5px;line-height:1.7}

/* LOCATION MARQUEE */
.marquee{background:linear-gradient(90deg,#000 0%,#1a0a1a 50%,#000 100%);border-top:1px solid var(--line);border-bottom:1px solid var(--line);overflow:hidden;padding:18px 0;position:relative}
.marquee-inner{display:flex;animation:marquee 50s linear infinite;gap:60px;white-space:nowrap;width:max-content}
.marquee:hover .marquee-inner{animation-play-state:paused}
.marquee-item{display:inline-flex;align-items:center;gap:14px;font-family:"Cormorant Garamond",serif;font-size:22px;color:var(--gold2);font-style:italic;font-weight:500}
.marquee-item:before{content:"◆";color:var(--gold);font-size:11px;font-style:normal}
@keyframes marquee{from{transform:translateX(0)}to{transform:translateX(-50%)}}

/* PRESS / TRUSTED BY STRIP */
.press-strip{background:#000;padding:50px 0;border-bottom:1px solid var(--line)}
.press-strip .label{text-align:center;font-size:11px;letter-spacing:.3em;text-transform:uppercase;color:var(--gold);font-weight:600;margin-bottom:30px}
.press-grid{display:flex;justify-content:center;align-items:center;flex-wrap:wrap;gap:60px;opacity:.7}
.press-logo{font-family:"Cormorant Garamond",serif;font-size:21px;color:#d8d8cc;letter-spacing:.04em;font-style:italic;font-weight:500;border-bottom:1px solid var(--line);padding-bottom:6px}
@media(max-width:680px){.press-grid{gap:30px}.press-logo{font-size:16px}}

/* FLOATING CALL BUTTON */
.float-cta{position:fixed;bottom:22px;right:22px;display:flex;flex-direction:column;gap:8px;z-index:200}
.float-cta a{background:var(--wine);color:#fff;padding:12px 18px;font-size:12.5px;font-weight:600;letter-spacing:.08em;text-transform:uppercase;border-radius:999px;display:inline-flex;align-items:center;gap:8px;box-shadow:0 12px 30px -8px rgba(0,0,0,.6);transition:all .25s var(--ease)}
.float-cta a:hover{transform:translateY(-2px);background:#9a2935;text-decoration:none}
.float-cta a.gold{background:var(--gradGold);color:#1a0e00}
.float-cta a.gold:hover{background:linear-gradient(135deg,#f0d878,#d4af37)}
@media(max-width:680px){.float-cta{bottom:14px;right:14px}.float-cta a{padding:10px 14px;font-size:11px}}

/* MIN BOOKING CALLOUT */
.min-callout{display:inline-flex;align-items:center;gap:10px;background:rgba(212,175,55,.08);border:1px solid var(--gold3);padding:10px 18px;border-radius:999px;font-size:12px;letter-spacing:.14em;text-transform:uppercase;color:var(--gold2);font-weight:600;margin-bottom:24px}
.min-callout:before{content:"";width:8px;height:8px;background:var(--gold);border-radius:50%;animation:pulse 2s ease-in-out infinite}
@keyframes pulse{0%,100%{opacity:1;transform:scale(1)}50%{opacity:.5;transform:scale(1.3)}}

/* STATS BIG */
.stats-big{padding:90px 0;background:#000;position:relative;overflow:hidden;border-top:1px solid var(--line)}
.stats-big:before{content:"";position:absolute;top:-300px;left:-300px;width:700px;height:700px;background:radial-gradient(circle,rgba(212,175,55,.06) 0%,transparent 70%);border-radius:50%}
.stats-big:after{content:"";position:absolute;bottom:-300px;right:-300px;width:700px;height:700px;background:radial-gradient(circle,rgba(122,31,43,.08) 0%,transparent 70%);border-radius:50%}
.stats-big .container{position:relative;z-index:2}
.stats-big-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:0}
@media(max-width:780px){.stats-big-grid{grid-template-columns:1fr 1fr;gap:30px 0}}
.stats-big .item{text-align:center;padding:0 24px;border-right:1px solid var(--line)}
.stats-big .item:last-child{border-right:none}
@media(max-width:780px){.stats-big .item{border-right:none;border-bottom:1px solid var(--line);padding:24px}.stats-big .item:nth-child(odd){border-right:1px solid var(--line)}.stats-big .item:nth-last-child(-n+2){border-bottom:none}}
.stats-big .item .big{font-family:"Cormorant Garamond",serif;font-size:clamp(60px,8vw,100px);color:var(--gold2);font-weight:300;line-height:1;letter-spacing:-.02em;margin-bottom:4px}
.stats-big .item .lbl{font-size:11px;letter-spacing:.24em;text-transform:uppercase;color:#a8a8a0;font-weight:600;margin-top:6px}
.stats-big .item .sub{font-size:13px;color:var(--mute);margin-top:8px;font-style:italic;font-family:"Cormorant Garamond",serif}

/* WHY US FEATURE */
.why-feature{display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:0;border:1px solid var(--line2)}
.why-feature .item{padding:42px 36px;border-right:1px solid var(--line);position:relative;background:var(--surf)}
.why-feature .item:last-child{border-right:none}
.why-feature .item:before{content:"";position:absolute;top:0;left:0;width:100%;height:2px;background:transparent;transition:background .3s var(--ease)}
.why-feature .item:hover:before{background:var(--gradGold)}
.why-feature .item .icon{font-family:"Cormorant Garamond",serif;font-style:italic;font-size:48px;color:var(--gold);line-height:1;margin-bottom:18px;font-weight:300}
.why-feature .item h4{font-family:"Cormorant Garamond",serif;font-size:22px;color:#fff;margin-bottom:10px;font-weight:500}
.why-feature .item p{color:var(--mute);font-size:14.5px;line-height:1.7}
@media(max-width:680px){.why-feature .item{border-right:none;border-bottom:1px solid var(--line)}.why-feature .item:last-child{border-bottom:none}}

/* SERVICE AREA MAP */
.area-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:24px;margin-top:30px}
@media(max-width:880px){.area-grid{grid-template-columns:1fr}}
.area-col{background:var(--surf);border:1px solid var(--line);padding:32px 30px}
.area-col h4{font-family:"Cormorant Garamond",serif;font-size:24px;color:var(--gold2);margin-bottom:18px;font-weight:500;display:flex;align-items:center;gap:10px}
.area-col h4 .ico{display:inline-flex;align-items:center;justify-content:center;width:34px;height:34px;border:1px solid var(--gold);border-radius:50%;font-size:14px;font-family:Inter,sans-serif;font-style:normal;font-weight:600;color:var(--gold2)}
.area-col ul{list-style:none;padding:0}
.area-col li{padding:9px 0;border-bottom:1px solid var(--line);color:#d8d8cc;font-size:14.5px;display:flex;justify-content:space-between;align-items:center;cursor:pointer;transition:color .2s var(--ease)}
.area-col li:hover{color:var(--gold2)}
.area-col li:last-child{border-bottom:none}
.area-col li small{color:var(--mute);font-size:11px;letter-spacing:.1em;text-transform:uppercase}

/* VIDEO WALKAROUND PLACEHOLDER */
.video-mockup{position:relative;border:1px solid var(--line);background:#000;margin-bottom:30px;overflow:hidden}
.video-thumb{aspect-ratio:16/9;background-size:cover;background-position:center;position:relative;cursor:pointer;transition:filter .3s var(--ease)}
.video-thumb:before{content:"";position:absolute;inset:0;background:linear-gradient(180deg,rgba(0,0,0,.15),rgba(0,0,0,.55));pointer-events:none}
.video-thumb:hover{filter:brightness(1.1)}
.play-btn{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);width:96px;height:96px;background:rgba(255,255,255,.96);color:#000;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:34px;padding-left:8px;cursor:pointer;transition:transform .25s var(--ease);box-shadow:0 16px 40px -10px rgba(0,0,0,.7)}
.video-thumb:hover .play-btn{transform:translate(-50%,-50%) scale(1.1);background:#fff}
.video-label{position:absolute;bottom:20px;left:24px;right:24px;color:#fff;font-family:"Cormorant Garamond",serif;font-size:20px;font-style:italic;text-shadow:0 2px 8px rgba(0,0,0,.6)}
.video-bar{padding:12px 18px;background:#0a0a0f;border-top:1px solid var(--line);display:flex;flex-direction:column;gap:9px}
.video-progress{height:3px;background:#2a2a35;border-radius:2px;overflow:hidden;cursor:pointer}
.video-played{height:100%;width:0%;background:var(--gold);transition:width .3s var(--ease)}
.video-controls{display:flex;gap:14px;color:#a8a8a0;font-size:11.5px;align-items:center;letter-spacing:.04em}
.video-controls .right{margin-left:auto;display:flex;gap:14px}
.video-coming{position:absolute;top:18px;right:18px;background:var(--wine);color:#fff;padding:6px 13px;font-size:10px;letter-spacing:.16em;text-transform:uppercase;font-weight:700;border-radius:3px;z-index:2;box-shadow:0 6px 16px -4px rgba(0,0,0,.5)}

/* LIVE AVAILABILITY WIDGET */
.avail-widget{background:#000;border:1px solid var(--gold);padding:40px 36px;position:relative;overflow:hidden}
.avail-widget:before{content:"";position:absolute;top:-200px;right:-200px;width:500px;height:500px;background:radial-gradient(circle,rgba(212,175,55,.08) 0%,transparent 70%);border-radius:50%;z-index:0}
.avail-widget > *{position:relative;z-index:1}
.avail-header{display:flex;justify-content:space-between;align-items:start;margin-bottom:24px;flex-wrap:wrap;gap:14px}
.avail-header .live-badge{display:inline-flex;align-items:center;gap:8px;font-size:10px;letter-spacing:.22em;text-transform:uppercase;color:var(--green);font-weight:700;margin-bottom:8px}
.avail-header .live-badge:before{content:"";width:7px;height:7px;background:var(--green);border-radius:50%;animation:pulse 1.5s ease-in-out infinite}
.avail-header h3{font-family:"Cormorant Garamond",serif;font-size:30px;color:#fff;font-weight:500;line-height:1.15}
.avail-header h3 em{color:var(--gold2);font-style:italic}
.avail-date-tabs{display:flex;gap:6px;flex-wrap:wrap}
.avail-date-tab{background:transparent;border:1px solid var(--line);color:#d8d8cc;padding:8px 14px;font-size:11px;letter-spacing:.12em;text-transform:uppercase;font-weight:600;cursor:pointer;font-family:inherit;transition:all .2s var(--ease)}
.avail-date-tab.active,.avail-date-tab:hover{background:var(--gold);color:#1a0e00;border-color:var(--gold)}
.avail-bus-row{display:grid;grid-template-columns:1fr 160px 110px;gap:14px;align-items:center;padding:14px 0;border-bottom:1px solid var(--line);font-size:14px}
@media(max-width:680px){.avail-bus-row{grid-template-columns:1fr 110px;gap:8px}.avail-bus-row .hide-mobile{display:none}}
.avail-bus-row:last-child{border-bottom:none}
.avail-bus-row .nm{color:#fff;font-weight:500}
.avail-bus-row .nm small{display:block;font-size:11px;color:var(--mute);font-weight:400;margin-top:2px}
.avail-bus-row .rt{color:var(--gold2);font-family:"Cormorant Garamond",serif;font-size:18px;font-weight:500}
.avail-bus-row .st{font-size:11px;letter-spacing:.14em;text-transform:uppercase;font-weight:700}
.avail-bus-row .st.av{color:var(--green)}
.avail-bus-row .st.few{color:var(--gold2)}
.avail-bus-row .st.bk{color:var(--red)}
.avail-bus-row .bk-btn{background:transparent;border:1px solid var(--line2);color:#fff;padding:8px 14px;font-size:11px;letter-spacing:.12em;text-transform:uppercase;font-weight:600;cursor:pointer;font-family:inherit;text-align:center;transition:all .2s var(--ease)}
.avail-bus-row .bk-btn:hover{border-color:var(--gold);color:var(--gold2)}
.avail-bus-row .bk-btn.gold{background:var(--gold);color:#1a0e00;border-color:var(--gold)}
.avail-bus-row .bk-btn.gold:hover{background:#f0d878}
.avail-bus-row .bk-btn.disabled{opacity:.4;cursor:not-allowed;border-color:var(--line)}

/* GOOGLE REVIEWS WIDGET */
.gw-widget{background:#0c0c12;border:1px solid var(--line2);padding:40px 36px;position:relative;overflow:hidden}
.gw-widget:before{content:"";position:absolute;top:-150px;right:-150px;width:400px;height:400px;background:radial-gradient(circle,rgba(66,133,244,.08) 0%,transparent 70%);border-radius:50%;z-index:0}
.gw-widget > *{position:relative;z-index:1}
.gw-header{display:flex;align-items:center;gap:24px;margin-bottom:30px;flex-wrap:wrap;padding-bottom:24px;border-bottom:1px solid var(--line)}
.gw-logo{display:flex;align-items:center;gap:14px}
.gw-logo .g-mark{width:54px;height:54px;background:#fff;border-radius:50%;display:flex;align-items:center;justify-content:center;font-family:'Product Sans',Arial,sans-serif;font-size:30px;font-weight:500;letter-spacing:-.02em;background-image:conic-gradient(from 0deg,#4285F4 0deg 90deg,#EA4335 90deg 180deg,#FBBC04 180deg 270deg,#34A853 270deg 360deg);background-clip:padding-box;border:3px solid #fff;position:relative}
.gw-logo .g-mark:after{content:"G";position:absolute;inset:3px;background:#fff;border-radius:50%;display:flex;align-items:center;justify-content:center;color:#4285F4;font-family:Arial,sans-serif;font-weight:500;font-size:28px}
.gw-logo .g-label{font-family:Arial,sans-serif;font-size:15px;color:#fff;font-weight:500;line-height:1.2}
.gw-logo .g-label small{color:var(--mute);font-size:12px;display:block;font-weight:400;margin-top:3px}
.gw-rating{display:flex;align-items:center;gap:16px;margin-left:auto}
.gw-rating .num-block{text-align:right}
.gw-rating .big{font-family:Arial,sans-serif;font-size:52px;color:#fff;font-weight:300;line-height:1}
.gw-rating .stars{color:#FBBC04;font-size:20px;letter-spacing:3px;margin-top:4px}
.gw-rating .count{font-size:12.5px;color:var(--mute);margin-top:6px;font-family:Arial,sans-serif}
.gw-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(290px,1fr));gap:16px}
.gw-card{background:rgba(255,255,255,.025);border:1px solid var(--line);padding:22px 24px;display:flex;flex-direction:column;gap:12px;font-family:Arial,sans-serif}
.gw-card .person{display:flex;align-items:center;gap:12px}
.gw-card .pp{width:42px;height:42px;border-radius:50%;background:#4285F4;color:#fff;display:flex;align-items:center;justify-content:center;font-size:17px;font-weight:600;flex:0 0 42px}
.gw-card .pp.green{background:#34A853}
.gw-card .pp.red{background:#EA4335}
.gw-card .pp.yellow{background:#FBBC04;color:#000}
.gw-card .pp.purple{background:#9c27b0}
.gw-card .pp.orange{background:#FF6D00}
.gw-card .pp.teal{background:#00ACC1}
.gw-card .meta{flex:1;min-width:0}
.gw-card .meta b{display:block;color:#fff;font-size:14.5px;font-weight:600;line-height:1.2}
.gw-card .meta .lg{display:inline-block;font-size:10px;font-weight:500;color:#4285F4;background:rgba(66,133,244,.15);padding:1px 7px;border-radius:2px;margin-left:6px;letter-spacing:.02em;vertical-align:middle}
.gw-card .meta span.sub{font-size:12px;color:var(--mute);display:block;margin-top:3px;font-weight:400}
.gw-card .stars-row{color:#FBBC04;font-size:13px;letter-spacing:2px}
.gw-card .stars-row .date{color:var(--mute);font-size:12px;margin-left:8px;letter-spacing:0;font-weight:400}
.gw-card .review-text{color:#d8d8cc;font-size:14px;line-height:1.6}
.gw-card .review-text .more{color:#4285F4;cursor:pointer}
.gw-card .review-actions{display:flex;align-items:center;gap:18px;padding-top:8px;margin-top:auto;font-size:12px;color:var(--mute)}
.gw-card .review-actions span:before{content:"";display:inline-block;width:12px;height:12px;border:1.5px solid currentColor;border-radius:50%;margin-right:5px;vertical-align:middle}
.gw-footer{display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:16px;margin-top:30px;padding-top:26px;border-top:1px solid var(--line)}
.gw-footer .note{color:var(--mute);font-size:12.5px;font-style:italic;max-width:560px;font-family:Arial,sans-serif;line-height:1.55}
.gw-btn-google{display:inline-flex;align-items:center;gap:10px;background:#fff;color:#3c4043;padding:12px 22px;font-family:Arial,sans-serif;font-size:13.5px;font-weight:500;border-radius:6px;text-decoration:none;transition:all .2s var(--ease);border:1px solid #dadce0}
.gw-btn-google:hover{background:#f8f9fa;text-decoration:none;color:#3c4043;box-shadow:0 2px 12px rgba(0,0,0,.3)}
.gw-btn-google .g-icon{width:18px;height:18px;display:inline-flex;align-items:center;justify-content:center;font-family:'Product Sans',Arial,sans-serif;font-weight:500;font-size:14px;background:conic-gradient(from 0deg,#4285F4 0deg 90deg,#EA4335 90deg 180deg,#FBBC04 180deg 270deg,#34A853 270deg 360deg);border-radius:50%;color:transparent;position:relative}
.gw-btn-google .g-icon:after{content:"G";position:absolute;inset:2px;background:#fff;border-radius:50%;color:#4285F4;display:flex;align-items:center;justify-content:center;font-size:11px}

/* GW STATE TOGGLE */
.gw-state-toggle{display:flex;gap:10px;justify-content:center;margin-bottom:30px;flex-wrap:wrap}
.gw-state-btn{background:transparent;border:1px solid var(--line2);color:#d8d8cc;padding:13px 26px;font-size:13px;letter-spacing:.06em;font-weight:600;cursor:pointer;font-family:inherit;transition:all .25s var(--ease);position:relative;text-align:center;line-height:1.2}
.gw-state-btn .lbl{display:block;font-size:10px;letter-spacing:.2em;text-transform:uppercase;margin-bottom:5px;color:var(--mute);font-weight:700}
.gw-state-btn.active{background:var(--gradGold);color:#1a0e00;border-color:var(--gold)}
.gw-state-btn.active .lbl{color:#3b2606;opacity:.85}
.gw-state-btn:not(.active):hover{border-color:var(--gold);color:var(--gold2)}
.gw-state-btn:not(.active):hover .lbl{color:var(--gold)}
.gw-state-btn.future-tag:before{content:"✦";position:absolute;top:-8px;right:-8px;width:22px;height:22px;background:var(--wine);color:#fff;font-size:11px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-weight:700;box-shadow:0 4px 10px -2px rgba(0,0,0,.5)}
.gw-state-now,.gw-state-future{display:none}
.gw-state-now.shown,.gw-state-future.shown{display:block;animation:fadeIn .35s var(--ease)}
.gw-state-future .gw-widget{border-color:var(--gold)}
.gw-future-badge{position:absolute;top:18px;right:18px;background:var(--wine);color:#fff;padding:6px 14px;font-size:10px;letter-spacing:.18em;text-transform:uppercase;font-weight:700;z-index:2;border-radius:3px;display:flex;align-items:center;gap:6px}
.gw-future-badge:before{content:"✦";font-size:11px}
.gw-delta{display:grid;grid-template-columns:repeat(auto-fit,minmax(160px,1fr));gap:14px;margin-top:28px;padding-top:24px;border-top:1px solid var(--line)}
