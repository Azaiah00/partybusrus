<script>
// Page routing
function navTo(page){
  document.querySelectorAll('.page').forEach(p=>p.classList.remove('active'));
  const el = document.getElementById('page-'+page);
  if(el){ el.classList.add('active'); }
  document.querySelectorAll('.nav-links a').forEach(a=>{
    a.classList.toggle('active', a.dataset.page===page);
  });
  // Update language toggle
  const isSpanish = page === 'home-es';
  document.querySelectorAll('.lang-toggle a').forEach(a=>{
    a.classList.toggle('on', (isSpanish && a.dataset.page === 'home-es') || (!isSpanish && a.dataset.page === 'home'));
  });
  // Toggle availability tabs (visual demo only)
  window.scrollTo({top:0,behavior:'instant'});
  history.replaceState(null,'','#'+page);
  document.querySelector('.mobile-nav').classList.remove('open');
}
// Avail date tabs (visual only)
document.querySelectorAll('.avail-date-tab').forEach(btn=>{
  btn.addEventListener('click',e=>{
    e.preventDefault();
    btn.parentElement.querySelectorAll('.avail-date-tab').forEach(b=>b.classList.remove('active'));
    btn.classList.add('active');
  });
});
// Gallery filter buttons — now actually filter by keyword
document.querySelectorAll('.gallery-filter button').forEach(btn=>{
  btn.addEventListener('click',e=>{
    e.preventDefault();
    btn.parentElement.querySelectorAll('button').forEach(b=>b.classList.remove('active'));
    btn.classList.add('active');
    const filter = btn.textContent.toLowerCase().trim();
    const isAll = filter.includes('all');
    // Find the closest grid (testimonial-grid OR gallery-grid)
    let container = btn.closest('.container');
    if (!container) return;
    const items = container.querySelectorAll('.testi, .gi');
    items.forEach(item => {
      if (isAll) { item.style.display = ''; return; }
      const text = item.textContent.toLowerCase();
      // Match keyword: e.g., "weddings" → "wedding" appears in card text
      const kw = filter.replace(/s$/, '').replace(/&amp;/g,'&');
      const kwShort = kw.split(' ')[0]; // first word
      if (text.includes(kw) || text.includes(kwShort)) {
        item.style.display = '';
      } else {
        item.style.display = 'none';
      }
    });
  });
});
// Google reviews state toggle (Today vs Q4 2026)
document.querySelectorAll('.gw-state-btn').forEach(btn=>{
  btn.addEventListener('click',e=>{
    e.preventDefault();
    const state = btn.dataset.gwState;
    document.querySelectorAll('.gw-state-btn').forEach(b=>b.classList.remove('active'));
    btn.classList.add('active');
    const nowEl = document.querySelector('.gw-state-now');
    const futureEl = document.querySelector('.gw-state-future');
    if(state === 'now'){
      nowEl.classList.add('shown');
      futureEl.classList.remove('shown');
    } else {
      nowEl.classList.remove('shown');
      futureEl.classList.add('shown');
    }
  });
});
document.querySelectorAll('[data-page]').forEach(el=>{
  el.style.cursor='pointer';
  el.addEventListener('click',e=>{
    e.preventDefault();
    navTo(el.dataset.page);
  });
});
// Initial hash
window.addEventListener('load',()=>{
  const h = window.location.hash.replace('#','');
  if(h && document.getElementById('page-'+h)) navTo(h);
});
window.addEventListener('hashchange',()=>{
  const h = window.location.hash.replace('#','');
  if(h && document.getElementById('page-'+h)) navTo(h);
});
</script>
