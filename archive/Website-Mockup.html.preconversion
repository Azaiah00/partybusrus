<style>
:root{
  --bg:#14101c;--bg2:#1c1626;--bg3:#251e30;--surf:#2a2236;--surf2:#352b41;
  --line:#3a3147;--line2:#4d425a;--text:#faf6ec;--mute:#c8bfb0;--dim:#8c8298;
  --gold:#d4af37;--gold2:#f4dc88;--gold3:#b88f1a;--wine:#8a2535;--royal:#7b5a9f;
  --gradGold:linear-gradient(135deg,#d4af37 0%,#f0d878 50%,#b58e1a 100%);
  --gradHero:linear-gradient(180deg,rgba(10,10,15,.2) 0%,rgba(10,10,15,.85) 100%);
  --ease:cubic-bezier(.2,.6,.2,1);
}
*{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{background:var(--bg);color:var(--text);font-family:"Inter",-apple-system,BlinkMacSystemFont,sans-serif;line-height:1.6;-webkit-font-smoothing:antialiased;overflow-x:hidden}
.serif{font-family:"Cormorant Garamond",Georgia,serif;font-weight:400}
a{color:inherit;text-decoration:none;transition:color .25s var(--ease)}
img{max-width:100%;display:block}
.container{max-width:1280px;margin:0 auto;padding:0 32px}
@media(max-width:680px){.container{padding:0 20px}}

/* TOP BAR */
.topbar{background:#000;color:#a8a8a0;font-size:12px;padding:8px 0;letter-spacing:.04em}
.topbar .container{display:flex;justify-content:space-between;align-items:center;gap:16px;flex-wrap:wrap}
.topbar a{color:var(--gold2)}
.topbar a:hover{color:#fff}

/* NAV */
nav.main{position:sticky;top:0;z-index:100;background:rgba(10,10,15,.92);backdrop-filter:blur(20px);border-bottom:1px solid var(--line);transition:all .3s var(--ease)}
nav.main .container{display:flex;align-items:center;justify-content:space-between;padding-top:14px;padding-bottom:14px;gap:32px}
.logo{display:flex;align-items:center;gap:14px;cursor:pointer;flex:0 0 auto;min-width:180px;margin-right:12px}
.logo .mark{height:62px;display:flex;align-items:center;justify-content:flex-start;flex:0 0 auto}
.logo .mark img{height:100%;width:auto;max-width:200px;object-fit:contain;display:block;filter:drop-shadow(0 2px 8px rgba(212,175,55,.18))}
@media(max-width:980px){.logo{min-width:0;margin-right:0}.logo .mark{height:50px}}
@media(max-width:680px){.logo .mark{height:44px}}
.logo .name{display:none}
.nav-links{display:flex;align-items:center;gap:30px}
.nav-links a{font-size:13px;letter-spacing:.08em;color:#d8d8cc;text-transform:uppercase;font-weight:500;padding:6px 0;position:relative}
.nav-links a:hover,.nav-links a.active{color:var(--gold2)}
.nav-links a.active:after{content:"";position:absolute;bottom:-4px;left:0;right:0;height:1px;background:var(--gold)}
.nav-cta{display:flex;align-items:center;gap:14px}
.btn{display:inline-flex;align-items:center;justify-content:center;gap:8px;padding:13px 26px;border-radius:2px;font-size:12.5px;font-weight:600;letter-spacing:.1em;text-transform:uppercase;cursor:pointer;border:none;transition:all .25s var(--ease);white-space:nowrap}
.btn.gold{background:var(--gradGold);color:#1a0e00}
.btn.gold:hover{transform:translateY(-1px);box-shadow:0 8px 24px -8px rgba(212,175,55,.5)}
.btn.ghost{background:transparent;color:#fff;border:1px solid var(--line2)}
.btn.ghost:hover{border-color:var(--gold);color:var(--gold2)}
.btn.wine{background:var(--wine);color:#fff}
.btn.wine:hover{background:#8a2935}
.btn.lg{padding:16px 36px;font-size:13.5px}
.btn .arrow{font-size:14px;line-height:1}
.menu-btn{display:none;background:transparent;border:none;color:#fff;font-size:24px;cursor:pointer}
@media(max-width:980px){
  .nav-links{display:none}
  .menu-btn{display:block}
  .nav-cta .btn.ghost{display:none}
}

/* PAGE SYSTEM */
.page{display:none;animation:fadeIn .4s var(--ease)}
.page.active{display:block}
@keyframes fadeIn{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:none}}

/* HERO */
.hero{position:relative;min-height:88vh;display:flex;align-items:center;overflow:hidden}
.hero-bg{position:absolute;inset:0;background-color:#14101c;background-image:linear-gradient(135deg,rgba(20,16,28,.42),rgba(20,16,28,.78)),url('IMG_8577.JPG');background-size:cover;background-position:center;filter:brightness(.65) saturate(1.05);animation:kenBurns 26s ease-in-out infinite alternate;transform-origin:center}
@keyframes kenBurns{from{transform:scale(1.08) translate(0,0)}to{transform:scale(1.16) translate(-1.5%,1%)}}
.hero-bg:before{content:"";position:absolute;inset:0;background:linear-gradient(135deg,rgba(10,10,15,.5) 0%,rgba(10,10,15,.85) 70%);}
.hero-inner{position:relative;z-index:2;padding:60px 0 80px;width:100%}
.hero .eyebrow{display:inline-flex;align-items:center;gap:10px;font-size:11px;letter-spacing:.28em;text-transform:uppercase;color:var(--gold2);margin-bottom:24px;font-weight:600}
.hero .eyebrow:before{content:"";width:32px;height:1px;background:var(--gold)}
.hero h1{font-family:"Cormorant Garamond",serif;font-size:clamp(48px,8vw,96px);line-height:1.02;letter-spacing:-.02em;font-weight:400;margin-bottom:24px;max-width:920px}
.hero h1 em{font-style:italic;color:var(--gold2);font-weight:300}
.hero .lede{font-size:clamp(17px,1.6vw,20px);color:#d8d8cc;max-width:580px;margin-bottom:42px;font-weight:300;line-height:1.55}
.hero-actions{display:flex;gap:14px;flex-wrap:wrap}
.hero-scroll{position:absolute;bottom:30px;left:50%;transform:translateX(-50%);z-index:3;color:var(--mute);font-size:10px;letter-spacing:.3em;text-transform:uppercase;display:flex;flex-direction:column;align-items:center;gap:10px}
.hero-scroll:after{content:"";width:1px;height:30px;background:linear-gradient(180deg,var(--gold),transparent);animation:scroll-pulse 2s ease-in-out infinite}
@keyframes scroll-pulse{0%,100%{transform:scaleY(.4);opacity:.4}50%{transform:scaleY(1);opacity:1}}

/* TRUST BAR */
.trustbar{background:#000;border-top:1px solid var(--line);border-bottom:1px solid var(--line);padding:28px 0}
.trustbar .container{display:flex;flex-wrap:wrap;justify-content:space-between;gap:24px;align-items:center}
.trust-item{display:flex;align-items:center;gap:12px;flex:1;min-width:140px}
.trust-item .ico{width:36px;height:36px;border:1px solid var(--gold);border-radius:50%;display:flex;align-items:center;justify-content:center;color:var(--gold2);font-family:"Cormorant Garamond",serif;font-style:italic;flex:0 0 36px;font-size:15px}
.trust-item .txt{font-size:13px;line-height:1.3}
.trust-item .txt b{color:#fff;display:block;font-size:14px;font-weight:600;letter-spacing:.02em}
.trust-item .txt span{color:var(--mute);font-size:11px;letter-spacing:.06em;text-transform:uppercase}

/* SECTIONS */
section.s{padding:100px 0;position:relative}
@media(max-width:680px){section.s{padding:64px 0}}

/* LED COLOR CYCLE */
.led-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:12px}
.led-tile{position:relative;aspect-ratio:3/4;background:#000;overflow:hidden;border:1px solid var(--line)}
.led-tile img{width:100%;height:100%;object-fit:cover;display:block;transition:transform .6s ease}
.led-tile:hover img{transform:scale(1.04)}
.led-tile .lbl{position:absolute;bottom:0;left:0;right:0;padding:14px 16px;background:linear-gradient(0deg,rgba(0,0,0,0.85),transparent);color:#fff;font-family:'Cormorant Garamond',serif;font-size:18px;letter-spacing:.04em}
@media(max-width:680px){.led-grid{grid-template-columns:repeat(2,1fr) !important}}
.section-head{margin-bottom:60px;text-align:center}
.section-head.left{text-align:left}
.section-head .kicker{display:inline-block;font-size:11px;letter-spacing:.3em;color:var(--gold);text-transform:uppercase;margin-bottom:18px;font-weight:600}
.section-head h2{font-family:"Cormorant Garamond",serif;font-size:clamp(36px,5vw,56px);line-height:1.05;letter-spacing:-.01em;font-weight:400;color:#fff;margin-bottom:18px}
.section-head h2 em{font-style:italic;color:var(--gold2);font-weight:300}
.section-head p{color:#bdbdb5;font-size:17px;font-weight:300;max-width:640px;margin:0 auto;line-height:1.6}
.section-head.left p{margin:0}

/* FLEET GRID */
.fleet-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(320px,1fr));gap:24px}
.bus-card{background:var(--surf);border:1px solid var(--line);overflow:hidden;cursor:pointer;transition:all .35s var(--ease);position:relative}
.bus-card:hover{transform:translateY(-4px);border-color:var(--gold2);box-shadow:0 24px 60px -20px rgba(0,0,0,.7)}
.bus-card .img{aspect-ratio:4/3;background-size:cover;background-position:center;position:relative;overflow:hidden}
.bus-card .img:after{content:"";position:absolute;inset:0;background:linear-gradient(180deg,transparent 50%,rgba(10,10,15,.7) 100%)}
.bus-card .badge{position:absolute;top:14px;left:14px;background:rgba(0,0,0,.7);color:var(--gold2);padding:6px 12px;border:1px solid var(--gold);font-size:11px;letter-spacing:.16em;text-transform:uppercase;z-index:2;font-weight:600}
.bus-card .body{padding:24px 26px 28px}
.bus-card .body h3{font-family:"Cormorant Garamond",serif;font-size:24px;font-weight:500;margin-bottom:6px;color:#fff}
.bus-card .body .cap{font-size:12px;color:var(--gold2);letter-spacing:.16em;text-transform:uppercase;margin-bottom:14px;font-weight:600}
.bus-card .body p{color:var(--mute);font-size:14px;margin-bottom:18px;line-height:1.55}
.bus-card .body .amenities{display:flex;flex-wrap:wrap;gap:6px;margin-bottom:18px}
.bus-card .body .amenities span{font-size:10px;letter-spacing:.12em;text-transform:uppercase;color:#d8d8cc;padding:4px 10px;border:1px solid var(--line2);border-radius:999px;font-weight:500}
.bus-card .body .footer{display:flex;align-items:center;justify-content:space-between;padding-top:18px;border-top:1px solid var(--line)}
.bus-card .body .price{font-family:"Cormorant Garamond",serif;font-size:22px;color:var(--gold2);font-weight:500}
.bus-card .body .price small{font-size:11px;color:var(--mute);letter-spacing:.1em;text-transform:uppercase;display:block;margin-top:2px;font-weight:500;font-family:Inter,sans-serif}
.bus-card .body .arrow{color:var(--gold2);font-size:18px}

/* SERVICES */
.services-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:1px;background:var(--line)}
.service{background:var(--bg2);padding:50px 38px;cursor:pointer;transition:background .3s var(--ease);position:relative;overflow:hidden}
.service:hover{background:var(--surf2)}
.service:before{content:"";position:absolute;top:0;left:0;right:0;height:2px;background:transparent;transition:background .3s var(--ease)}
.service:hover:before{background:var(--gradGold)}
.service .icon{font-family:"Cormorant Garamond",serif;font-style:italic;font-size:32px;color:var(--gold2);margin-bottom:24px;font-weight:300}
.service h3{font-family:"Cormorant Garamond",serif;font-size:24px;font-weight:500;color:#fff;margin-bottom:12px}
.service p{color:var(--mute);font-size:14.5px;margin-bottom:18px;line-height:1.6}
.service .link{font-size:11px;letter-spacing:.18em;text-transform:uppercase;color:var(--gold2);font-weight:600;display:inline-flex;align-items:center;gap:8px}

/* PRICING TEASER */
.pricing-teaser{background:linear-gradient(135deg,#1a1424 0%,#2a1830 50%,#1c1626 100%);position:relative;overflow:hidden}
.pricing-teaser:before{content:"";position:absolute;top:-200px;right:-200px;width:600px;height:600px;background:radial-gradient(circle,rgba(212,175,55,.12) 0%,transparent 70%);border-radius:50%}
.pricing-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:0;margin-top:50px;border:1px solid var(--line2);background:rgba(0,0,0,.3)}
.pricing-col{padding:42px 32px;border-right:1px solid var(--line)}
.pricing-col:last-child{border-right:none}
.pricing-col .cap{font-size:11px;letter-spacing:.24em;color:var(--gold);text-transform:uppercase;margin-bottom:14px;font-weight:600}
.pricing-col h4{font-family:"Cormorant Garamond",serif;font-size:28px;color:#fff;margin-bottom:18px;font-weight:500}
.pricing-col .price{font-family:"Cormorant Garamond",serif;font-size:48px;color:var(--gold2);font-weight:500;line-height:1;margin-bottom:6px}
.pricing-col .price small{font-size:14px;color:var(--mute);font-family:Inter;font-weight:500}
.pricing-col .sub{font-size:13px;color:var(--mute);margin-bottom:18px}
@media(max-width:780px){.pricing-grid{grid-template-columns:1fr}.pricing-col{border-right:none;border-bottom:1px solid var(--line)}}
.pricing-incl{display:flex;flex-wrap:wrap;gap:30px;justify-content:center;margin-top:40px;color:var(--mute);font-size:13.5px}
.pricing-incl span{display:inline-flex;align-items:center;gap:8px}
.pricing-incl span:before{content:"✓";color:var(--gold);font-weight:700}

/* TESTIMONIALS */
.testimonials:not(.s-light){background:var(--bg2)}
.testimonial-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(290px,1fr));gap:24px}
.testi{background:transparent;border:1px solid var(--line);padding:36px 32px;position:relative}
.testi .stars{color:var(--gold);font-size:14px;margin-bottom:18px;letter-spacing:.08em}
.testi .quote{font-family:"Cormorant Garamond",serif;font-size:19px;line-height:1.5;color:#e8e8dc;font-weight:400;margin-bottom:22px;font-style:italic}
.testi .author{display:flex;align-items:center;gap:14px;padding-top:18px;border-top:1px solid var(--line)}
.testi .author .avatar{width:42px;height:42px;border-radius:50%;background:var(--surf2);border:1px solid var(--gold);display:flex;align-items:center;justify-content:center;font-family:"Cormorant Garamond",serif;font-style:italic;color:var(--gold2);font-weight:500;font-size:16px;flex:0 0 42px}
.testi .author .info b{display:block;font-size:14px;color:#fff;font-weight:600}
.testi .author .info span{font-size:11.5px;color:var(--mute);letter-spacing:.06em;text-transform:uppercase;margin-top:2px;display:block}
.review-summary{display:flex;align-items:center;justify-content:center;gap:30px;margin-top:50px;flex-wrap:wrap}
.review-summary .pill{display:flex;align-items:center;gap:10px;padding:12px 22px;background:var(--surf);border:1px solid var(--line);border-radius:999px}
.review-summary .pill .num{font-family:"Cormorant Garamond",serif;font-size:22px;color:var(--gold2);font-weight:600;line-height:1}
.review-summary .pill .lbl{font-size:11px;letter-spacing:.14em;text-transform:uppercase;color:var(--mute);font-weight:500}

/* HOW IT WORKS */
.steps{display:grid;grid-template-columns:repeat(3,1fr);gap:32px;position:relative}
@media(max-width:780px){.steps{grid-template-columns:1fr}}
.step{position:relative;text-align:center}
.step .num{font-family:"Cormorant Garamond",serif;font-style:italic;font-size:80px;color:var(--gold3);font-weight:400;line-height:1;opacity:.6;margin-bottom:8px}
.step h4{font-family:"Cormorant Garamond",serif;font-size:24px;color:#fff;font-weight:500;margin-bottom:12px}
.step p{color:var(--mute);font-size:14.5px;line-height:1.6;max-width:280px;margin:0 auto}

/* FAQ */
.faq{max-width:880px;margin:0 auto}
.faq-item{border-bottom:1px solid var(--line);overflow:hidden}
.faq-item summary{padding:24px 0;cursor:pointer;display:flex;justify-content:space-between;align-items:center;list-style:none;color:#fff;font-family:"Cormorant Garamond",serif;font-size:22px;font-weight:500;transition:color .25s var(--ease);gap:24px}
.faq-item summary::-webkit-details-marker{display:none}
.faq-item summary:hover{color:var(--gold2)}
.faq-item summary .plus{flex:0 0 32px;font-size:20px;color:var(--gold);font-weight:300;transition:transform .35s var(--ease)}
.faq-item[open] summary .plus{transform:rotate(45deg)}
.faq-item .ans{padding:0 0 28px;color:var(--mute);font-size:15px;line-height:1.7;max-width:780px}

/* FINAL CTA */
.final-cta{position:relative;background-color:#14101c;background-image:url('IMG_0156.JPG');background-size:cover;background-position:center;background-attachment:fixed;padding:140px 0;text-align:center;overflow:hidden}
.final-cta:before{content:"";position:absolute;inset:0;background:linear-gradient(135deg,rgba(10,10,15,.85),rgba(10,10,15,.6))}
.final-cta .container{position:relative;z-index:2}
.final-cta h2{font-family:"Cormorant Garamond",serif;font-size:clamp(40px,6vw,72px);font-weight:300;color:#fff;margin-bottom:18px;line-height:1.05}
.final-cta h2 em{color:var(--gold2);font-style:italic}
.final-cta p{font-size:18px;color:#d8d8cc;margin-bottom:36px;font-weight:300}
.final-cta-actions{display:inline-flex;gap:14px;flex-wrap:wrap;justify-content:center}

/* FOOTER */
footer{background:#000;color:var(--mute);padding:80px 0 30px;border-top:1px solid var(--line)}
.footer-grid{display:grid;grid-template-columns:1.6fr 1fr 1fr 1fr 1fr;gap:36px;margin-bottom:60px}
@media(max-width:980px){.footer-grid{grid-template-columns:1fr 1fr 1fr;gap:32px}}
@media(max-width:680px){.footer-grid{grid-template-columns:1fr 1fr;gap:28px}}
.footer-col h5{font-size:11px;letter-spacing:.22em;text-transform:uppercase;color:var(--gold);margin-bottom:20px;font-weight:600}
.footer-col p{font-size:14px;line-height:1.7}
.footer-col a{display:block;font-size:14px;padding:5px 0}
.footer-col a:hover{color:var(--gold2)}
.footer-bottom{padding-top:30px;border-top:1px solid var(--line);display:flex;justify-content:space-between;flex-wrap:wrap;gap:20px;font-size:12px;color:var(--dim)}
.footer-bottom .creds{display:flex;gap:14px;color:var(--mute)}
.footer-logo{margin-bottom:18px;line-height:1}
.footer-logo img{max-width:260px;width:100%;height:auto;display:block;filter:drop-shadow(0 2px 6px rgba(212,175,55,.15))}
.social{display:flex;gap:12px;margin-top:18px}
.social a{width:36px;height:36px;border:1px solid var(--line2);border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:13px;padding:0;color:#d8d8cc;font-family:"Cormorant Garamond",serif;font-style:italic;transition:all .25s var(--ease)}
.social a:hover{border-color:var(--gold);color:var(--gold2);background:rgba(212,175,55,.05)}

/* GENERIC PAGE HEADER */
.page-hero{position:relative;padding:140px 0 80px;overflow:hidden;border-bottom:1px solid var(--line)}
.page-hero-bg{position:absolute;inset:0;background-color:#14101c;background-size:cover;background-position:center;filter:brightness(.4) saturate(1.1);z-index:0}
.page-hero-bg:after{content:"";position:absolute;inset:0;background:linear-gradient(180deg,rgba(10,10,15,.3) 0%,rgba(10,10,15,.9) 100%)}
.page-hero .container{position:relative;z-index:2}
.breadcrumb{font-size:11px;letter-spacing:.18em;text-transform:uppercase;color:var(--mute);margin-bottom:20px}
.breadcrumb a:hover{color:var(--gold2)}
.breadcrumb .sep{color:var(--gold);margin:0 8px}
.page-hero h1{font-family:"Cormorant Garamond",serif;font-size:clamp(42px,6vw,78px);font-weight:400;color:#fff;line-height:1.05;margin-bottom:16px;max-width:880px}
.page-hero h1 em{color:var(--gold2);font-style:italic;font-weight:300}
.page-hero p{font-size:18px;color:#d8d8cc;max-width:640px;font-weight:300}

/* DETAIL PAGE */
.detail-grid{display:grid;grid-template-columns:1fr 460px;gap:64px;align-items:start}
@media(max-width:980px){.detail-grid{grid-template-columns:1fr;gap:40px}}
.gallery{display:grid;grid-template-columns:repeat(4,1fr);gap:8px;grid-template-rows:repeat(2,1fr);height:auto}
.gallery .g{aspect-ratio:1;background-size:cover;background-position:center;border:1px solid var(--line);cursor:pointer;transition:opacity .25s var(--ease)}
.gallery .g.main{grid-column:span 4;aspect-ratio:16/10}
.gallery .g:hover{opacity:.85}
.detail-side{position:sticky;top:100px}
.detail-side .price-box{background:var(--surf);border:1px solid var(--gold);padding:32px 30px;margin-bottom:24px}
.detail-side .price-box .from{font-size:11px;letter-spacing:.2em;color:var(--gold);text-transform:uppercase;font-weight:600;margin-bottom:8px}
.detail-side .price-box .num{font-family:"Cormorant Garamond",serif;font-size:54px;color:#fff;font-weight:500;line-height:1;margin-bottom:6px}
.detail-side .price-box .num small{font-size:18px;color:var(--mute);font-family:Inter}
.detail-side .price-box .notes{color:var(--mute);font-size:13px;margin:14px 0 22px;line-height:1.55}
.detail-side .price-box .btn{width:100%}
.detail-side .quick-call{padding:20px;background:var(--bg2);border:1px solid var(--line);text-align:center;font-size:13.5px;color:var(--mute)}
.detail-side .quick-call b{display:block;color:#fff;font-family:"Cormorant Garamond",serif;font-size:22px;margin-bottom:4px}
.detail-content h3{font-family:"Cormorant Garamond",serif;font-size:32px;color:#fff;margin:36px 0 16px;font-weight:500}
.detail-content p{color:#bdbdb5;font-size:16px;line-height:1.75;margin-bottom:16px}
.spec-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:20px;margin:24px 0}
.spec{padding:20px 22px;background:var(--bg2);border:1px solid var(--line)}
.spec .lbl{font-size:11px;letter-spacing:.18em;text-transform:uppercase;color:var(--gold);font-weight:600;margin-bottom:8px}
.spec .val{font-family:"Cormorant Garamond",serif;font-size:22px;color:#fff;font-weight:500}
.amenity-list{display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:10px;margin:18px 0}
.amenity-list li{list-style:none;padding:11px 14px;background:var(--bg2);border-left:2px solid var(--gold);color:#d8d8cc;font-size:14px;display:flex;align-items:center;gap:10px}

/* CITY PAGE */
.city-grid{display:grid;grid-template-columns:1.4fr 1fr;gap:60px;align-items:start;margin-bottom:60px}
@media(max-width:980px){.city-grid{grid-template-columns:1fr}}
.city-content h3{font-family:"Cormorant Garamond",serif;font-size:28px;color:#fff;margin:30px 0 14px;font-weight:500}
.city-content p{color:#bdbdb5;font-size:16px;line-height:1.75;margin-bottom:14px}
.routes{background:var(--bg2);border:1px solid var(--line);padding:32px}
.routes h3{font-family:"Cormorant Garamond",serif;font-size:26px;margin-bottom:24px;color:#fff;font-weight:500}
.route{display:flex;justify-content:space-between;align-items:center;padding:16px 0;border-bottom:1px solid var(--line);font-size:14.5px}
.route:last-child{border-bottom:none}
.route .to{color:#fff;font-weight:500}
.route .meta{color:var(--mute);font-size:12px;letter-spacing:.06em;text-transform:uppercase}

/* PRICING PAGE */
.price-table{width:100%;border-collapse:collapse;background:var(--surf);border:1px solid var(--line2);margin:30px 0}
.price-table th,.price-table td{padding:18px 22px;text-align:left;border-bottom:1px solid var(--line)}
.price-table th{background:#000;font-size:11px;letter-spacing:.16em;text-transform:uppercase;color:var(--gold);font-weight:600}
.price-table tr:last-child td{border-bottom:none}
.price-table tr:hover td{background:rgba(212,175,55,.04)}
.price-table .vehicle{font-family:"Cormorant Garamond",serif;font-size:19px;color:#fff;font-weight:500}
.price-table .rate{font-family:"Cormorant Garamond",serif;font-size:22px;color:var(--gold2);font-weight:500}
.price-table .min{font-size:13px;color:var(--mute)}

/* QUOTE FORM */
.quote-grid{display:grid;grid-template-columns:1.2fr 1fr;gap:60px;align-items:start}
@media(max-width:980px){.quote-grid{grid-template-columns:1fr}}
.quote-form{background:var(--surf);border:1px solid var(--line2);padding:48px 44px}
@media(max-width:680px){.quote-form{padding:30px 22px}}
.quote-form h3{font-family:"Cormorant Garamond",serif;font-size:30px;color:#fff;margin-bottom:24px;font-weight:500}
.form-grid{display:grid;grid-template-columns:1fr 1fr;gap:16px}
.field{margin-bottom:18px}
.field.full{grid-column:span 2}
.field label{display:block;font-size:11px;letter-spacing:.16em;text-transform:uppercase;color:var(--gold);margin-bottom:8px;font-weight:600}
.field input,.field select,.field textarea{width:100%;background:var(--bg2);border:1px solid var(--line2);color:#fff;padding:14px 16px;font-family:inherit;font-size:15px;transition:border .25s var(--ease)}
.field input:focus,.field select:focus,.field textarea:focus{outline:none;border-color:var(--gold)}
.field textarea{resize:vertical;min-height:90px}
.quote-side h3{font-family:"Cormorant Garamond",serif;font-size:28px;color:#fff;margin-bottom:14px;font-weight:500}
.quote-side p{color:var(--mute);font-size:15px;line-height:1.7;margin-bottom:20px}
.contact-card{background:var(--bg2);border:1px solid var(--line);padding:24px;margin-bottom:20px}
.contact-card .lbl{font-size:11px;letter-spacing:.16em;text-transform:uppercase;color:var(--gold);font-weight:600;margin-bottom:6px}
.contact-card .val{font-family:"Cormorant Garamond",serif;font-size:22px;color:#fff;font-weight:500}

/* MOBILE NAV */
.mobile-nav{position:fixed;inset:0;background:rgba(10,10,15,.98);backdrop-filter:blur(20px);z-index:200;display:none;flex-direction:column;padding:30px;animation:fadeIn .25s var(--ease)}
.mobile-nav.open{display:flex}
.mobile-nav .close{position:absolute;top:24px;right:24px;background:none;border:none;color:#fff;font-size:28px;cursor:pointer}
.mobile-nav .links{margin-top:80px;display:flex;flex-direction:column;gap:8px}
.mobile-nav a{font-family:"Cormorant Garamond",serif;font-size:30px;color:#fff;padding:12px 0;border-bottom:1px solid var(--line)}
.mobile-nav a:hover{color:var(--gold2)}

